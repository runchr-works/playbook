{
  "name": "memkit",
  "version": "0.1.0",
  "description": "One-stop setup CLI for MCP-powered coding agent tools",
  "type": "module",
  "bin": {
    "memkit": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runchr-works/playbook.git",
    "directory": "memkit"
  },
  "homepage": "https://github.com/runchr-works/playbook/tree/main/memkit#readme",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "smoke": "node scripts/smoke.mjs",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=22.5"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
