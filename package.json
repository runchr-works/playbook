{
  "name": "intentir",
  "version": "0.1.0",
  "description": "A provider-based cognition layer for AI agents",
  "type": "module",
  "bin": {
    "intentir": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runchr-works/intentir.git"
  },
  "homepage": "https://github.com/runchr-works/intentir#readme",
  "bugs": "https://github.com/runchr-works/intentir/issues",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.ko.md",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "smoke": "node scripts/smoke.mjs",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=22.5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
